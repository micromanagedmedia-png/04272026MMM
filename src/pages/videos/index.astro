---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { publishedVideos } from '../../data/videos';

const BOOK_URL = 'https://calendar.app.google/RUTjw3N7Afe95Tkk8';
const APP_URL = 'https://micromanagedmedia.com';

const categoryColors: Record<string, string> = {
  'Google Ads': 'bg-blue-900/40 text-blue-300',
  'Call Tracking': 'bg-cyan-900/40 text-cyan-300',
  'Reviews & Reputation': 'bg-cyan-900/40 text-cyan-300',
  'AI & Automation': 'bg-blue-900/40 text-blue-300',
  'Google Maps': 'bg-blue-900/40 text-blue-300',
  'SEO & Video Marketing': 'bg-purple-900/40 text-purple-300',
};

const pageTitle = 'Contractor Marketing Video Guides | MicroManaged Media';
const pageDescription =
  'Step-by-step video guides on Google Ads, call tracking, reputation management, and AI automation — built specifically for local service contractors.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Contractor Marketing Video Library',
  description: pageDescription,
  url: `${APP_URL}/videos`,
  publisher: {
    '@type': 'Organization',
    name: 'MicroManaged Media',
    url: APP_URL,
  },
};
---

<Layout title={pageTitle} description={pageDescription} canonical={`${APP_URL}/videos`}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-slate-50 pt-32 pb-24 overflow-hidden">
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 70% 40%, hsl(196 94% 40%) 0%, transparent 55%);"
    ></div>
    <div class="container mx-auto px-6 relative z-10">
      <Breadcrumb items={[{ label: 'Videos' }]} variant="dark" class="mb-8" />
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-12 h-12 rounded-2xl bg-accent/20 border border-primary/30 flex items-center justify-center">
            <!-- YouTube icon -->
            <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
          <span class="text-primary text-sm font-semibold uppercase tracking-widest">Video Library</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-foreground tracking-tight leading-tight mb-5">
          Contractor Marketing<br />
          <span class="text-primary">Video Guides</span>
        </h1>
        <p class="text-foreground/70 text-xl leading-relaxed max-w-2xl">
          Step-by-step video guides on Google Ads, call tracking, reputation management, and AI automation — built
          specifically for local service contractors.
        </p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent dark:from-[#0f172a]"></div>
  </section>

  <!-- Stats bar -->
  <section class="bg-gray-50 /40 border-b border-gray-200 ">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-200 dark:divide-gray-700">
        {[
          { value: String(publishedVideos.length), label: 'Video Guides' },
          { value: 'Free', label: 'Always' },
          { value: '20+', label: 'Years Experience' },
          { value: '100%', label: 'Contractor Focused' },
        ].map((s) => (
          <div class="py-6 px-4 text-center">
            <div class="text-2xl md:text-3xl font-black text-blue-900 dark:text-blue-300">{s.value}</div>
            <div class="text-xs text-gray-500 mt-1 uppercase tracking-wider">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Video Grid -->
  <section class="py-20 bg-white dark:bg-white">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
        {publishedVideos.map((video) => {
          const thumb = `https://img.youtube.com/vi/${video.youtubeId}/maxresdefault.jpg`;
          const colorClass = categoryColors[video.category] ?? 'bg-gray-100 text-gray-600';
          return (
            <a
              href={`/videos/${video.slug}`}
              class="group flex flex-col h-full bg-white  border border-gray-200  hover:border-primary/40 hover:shadow-lg rounded-2xl overflow-hidden transition-all duration-300"
            >
              <!-- Thumbnail -->
              <div class="relative aspect-video bg-gray-100  overflow-hidden">
                <img
                  src={thumb}
                  alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror={`this.src='https://img.youtube.com/vi/${video.youtubeId}/hqdefault.jpg'`}
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/30 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                  <div class="w-14 h-14 rounded-full bg-accent flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-300">
                    <svg class="w-6 h-6 text-foreground fill-white ml-1" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
                <!-- Duration badge -->
                <div class="absolute bottom-2 right-2 bg-black/80 text-foreground text-xs font-mono px-2 py-0.5 rounded">
                  {video.durationDisplay}
                </div>
              </div>

              <!-- Content -->
              <div class="flex flex-col flex-1 p-5">
                <div class="flex items-center justify-between mb-3">
                  <span class={`text-xs font-bold px-2.5 py-1 rounded-full ${colorClass}`}>
                    {video.category}
                  </span>
                  <span class="flex items-center gap-1 text-gray-500 text-xs">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                    </svg>
                    {video.durationDisplay}
                  </span>
                </div>
                <h3 class="font-black text-gray-900 text-foreground group-hover:text-blue-600  transition-colors text-base leading-snug tracking-tight mb-3 flex-1">
                  {video.title}
                </h3>
                <p class="text-gray-500  text-sm leading-relaxed line-clamp-2 mb-4">
                  {video.description}
                </p>
                <div class="flex items-center gap-1 text-cyan-500 text-sm font-semibold">
                  Watch video
                  <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-50 relative overflow-hidden">
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(ellipse at 50% 100%, hsl(196 94% 40%) 0%, transparent 60%);"
    ></div>
    <div class="container mx-auto px-6 text-center max-w-2xl relative">
      <h2 class="text-3xl md:text-4xl font-black text-foreground mb-4 tracking-tight">
        Want a Custom Strategy for Your Business?
      </h2>
      <p class="text-foreground/60 text-lg mb-8 leading-relaxed">
        These videos give you the framework. We handle the execution — building and managing the campaigns that
        actually fill your schedule.
      </p>
      <a
        href={BOOK_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-accent hover:bg-cyan-300 text-white font-bold px-10 py-4 rounded-full transition-colors"
      >
        Book a Free Strategy Call
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-foreground/40 text-xs uppercase tracking-widest">
        <span>✓ 20+ Years Experience</span>
        <span>✓ Contractor Specialists</span>
        <span>✓ No Obligation</span>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { publishedVideos, getVideo, getRelatedVideos } from '../../data/videos';

export async function getStaticPaths() {
  return publishedVideos.map((video) => ({
    params: { slug: video.slug },
    props: { video },
  }));
}

const { video } = Astro.props;
const related = getRelatedVideos(video.slug, 3);

const APP_URL = 'https://micromanagedmedia.com';
const BOOK_URL = 'https://calendar.app.google/RUTjw3N7Afe95Tkk8';

const thumbHigh = `https://img.youtube.com/vi/${video.youtubeId}/maxresdefault.jpg`;
const uploadFormatted = new Date(video.uploadDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  'Google Ads': 'bg-blue-900/40 text-blue-300',
  'Call Tracking': 'bg-cyan-900/40 text-cyan-300',
  'Reviews & Reputation': 'bg-cyan-900/40 text-cyan-300',
  'AI & Automation': 'bg-blue-900/40 text-blue-300',
  'Google Maps': 'bg-blue-900/40 text-blue-300',
  'SEO & Video Marketing': 'bg-purple-900/40 text-purple-300',
};
const colorClass = categoryColors[video.category] ?? 'bg-gray-700 text-gray-600';

// JSON-LD: VideoObject schema
const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: video.title,
  description: video.description,
  thumbnailUrl: [
    `https://img.youtube.com/vi/${video.youtubeId}/maxresdefault.jpg`,
    `https://img.youtube.com/vi/${video.youtubeId}/hqdefault.jpg`,
  ],
  uploadDate: `${video.uploadDate}T08:00:00+00:00`,
  duration: video.duration,
  contentUrl: `https://www.youtube.com/watch?v=${video.youtubeId}`,
  embedUrl: `https://www.youtube.com/embed/${video.youtubeId}`,
  url: `${APP_URL}/videos/${video.slug}`,
  publisher: {
    '@type': 'Organization',
    name: 'MicroManaged Media',
    url: APP_URL,
    logo: {
      '@type': 'ImageObject',
      url: `${APP_URL}/logo.png`,
      width: 200,
      height: 200,
    },
  },
  keywords: video.tags.join(', '),
};

// JSON-LD: BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: APP_URL },
    { '@type': 'ListItem', position: 2, name: 'Videos', item: `${APP_URL}/videos` },
    { '@type': 'ListItem', position: 3, name: video.title, item: `${APP_URL}/videos/${video.slug}` },
  ],
};

// Split long description for rendering
const descParagraphs = video.longDescription
  .split('\n')
  .map((p: string) => p.trim())
  .filter((p: string) => p.length > 0);
---

<Layout
  title={`${video.title} | MicroManaged Media`}
  description={video.description}
  canonical={`${APP_URL}/videos/${video.slug}`}
  ogImage={thumbHigh}
  ogType="video.other"
>
  <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <Navbar />

  <!-- Sticky desktop action bar -->
  <div class="hidden md:flex fixed top-[72px] left-0 right-0 z-40 bg-white/95 /95 backdrop-blur border-b border-gray-200  shadow-sm">
    <div class="container mx-auto px-6 max-w-5xl flex items-center justify-end gap-3 py-2.5">
      <a
        href={`https://www.youtube.com/watch?v=${video.youtubeId}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-semibold text-gray-700  border border-gray-200  hover:border-primary/60 bg-white  hover:bg-gray-50 px-4 py-2 rounded-full transition-colors"
      >
        <!-- YouTube icon -->
        <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Watch on YouTube
      </a>
      <a
        href={BOOK_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-bold bg-accent hover:bg-cyan-300 text-white px-5 py-2 rounded-full transition-colors"
      >
        Book a Free Call
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Hero — video embed is primary above-the-fold content -->
  <section class="bg-slate-50 pt-28 md:pt-36 pb-10 relative overflow-hidden">
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 70% 40%, hsl(196 94% 40%) 0%, transparent 55%);"
    ></div>
    <div class="container mx-auto px-6 relative z-10 max-w-5xl">
      <Breadcrumb
        items={[{ label: 'Videos', href: '/videos' }, { label: video.title }]}
        variant="dark"
        class="mb-6"
      />
      <h1 class="text-2xl md:text-4xl font-black text-foreground tracking-tight leading-tight mb-6 max-w-3xl">
        {video.title}
      </h1>

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-4 mb-8 text-foreground/60 text-sm">
        <span class="text-xs font-bold px-3 py-1 rounded-full bg-white/15 text-foreground">
          {video.category}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          {video.durationDisplay}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {uploadFormatted}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-red-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          MicroManaged Media
        </span>
      </div>
    </div>

    <!-- VIDEO EMBED — primary above-the-fold content -->
    <div class="container mx-auto px-6 max-w-5xl relative z-10">
      <div class="w-full aspect-video rounded-2xl overflow-hidden shadow-2xl border border-border">
        <iframe
          src={`https://www.youtube.com/embed/${video.youtubeId}?rel=0&modestbranding=1&autoplay=0`}
          title={video.title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          class="w-full h-full"
          loading="lazy"
        ></iframe>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white dark:from-gray-950 to-transparent"></div>
  </section>

  <!-- Main content -->
  <div class="container mx-auto px-6 py-14 max-w-5xl">
    <div class="grid lg:grid-cols-3 gap-12">

      <!-- Left: Description -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-black text-gray-900 text-foreground tracking-tight mb-5">About This Video</h2>
        <div class="space-y-4">
          {descParagraphs.map((para: string) =>
            para.startsWith('•') ? (
              <div class="flex items-start gap-2.5 text-gray-500 ">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"></span>
                <span class="leading-relaxed text-[1.0625rem]">{para.replace('•', '').trim()}</span>
              </div>
            ) : (
              <p class="text-gray-500  leading-relaxed text-[1.0625rem]">{para}</p>
            )
          )}
        </div>

        <!-- Tags -->
        <div class="mt-10 pt-8 border-t border-gray-200 ">
          <div class="flex items-center gap-2 flex-wrap">
            <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
            {video.tags.map((tag: string) => (
              <span class="text-xs bg-gray-100  text-gray-500  px-3 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Watch on YouTube -->
        <div class="mt-6">
          <a
            href={`https://www.youtube.com/watch?v=${video.youtubeId}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-primary transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            Watch on YouTube
          </a>
        </div>

        <!-- Related videos (mobile) -->
        {related.length > 0 && (
          <div class="lg:hidden mt-12">
            <h3 class="text-xl font-black text-gray-900 text-foreground tracking-tight mb-5">More Videos</h3>
            <div class="space-y-4">
              {related.map((v) => {
                const relThumb = `https://img.youtube.com/vi/${v.youtubeId}/hqdefault.jpg`;
                return (
                  <a
                    href={`/videos/${v.slug}`}
                    class="group flex gap-4 items-start bg-white  border border-gray-200  hover:border-primary/40 hover:shadow-md rounded-2xl p-4 transition-all duration-200"
                  >
                    <div class="relative w-28 shrink-0 aspect-video rounded-xl overflow-hidden bg-gray-100 ">
                      <img src={relThumb} alt={v.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                      <div class="absolute inset-0 bg-black/25 flex items-center justify-center">
                        <svg class="w-4 h-4 text-foreground fill-white" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                      </div>
                      <div class="absolute bottom-1 right-1 bg-black/80 text-foreground text-[10px] font-mono px-1.5 py-0.5 rounded">{v.durationDisplay}</div>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h4 class="text-sm font-bold text-gray-900 text-foreground group-hover:text-primary transition-colors leading-snug line-clamp-2 mb-1">{v.title}</h4>
                      <span class="text-xs text-gray-500 flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {v.durationDisplay}
                      </span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}
      </div>

      <!-- Right: Sidebar -->
      <aside class="space-y-6">
        <div class="sticky top-24 space-y-5">

          <!-- CTA card -->
          <div class="bg-slate-50 rounded-2xl p-7 text-foreground">
            <h3 class="font-bold text-lg mb-3 leading-snug">Want Us to Handle This for You?</h3>
            <p class="text-foreground/70 text-sm leading-relaxed mb-5">
              We build and manage these exact systems for contractors across 50 U.S. markets. Book a free call to
              see what's possible for your business.
            </p>
            <a
              href={BOOK_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full bg-accent hover:bg-cyan-300 text-white font-bold py-3 px-5 rounded-xl transition-colors"
            >
              Book a Free Call
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

          <!-- Related videos (desktop) -->
          {related.length > 0 && (
            <div class="hidden lg:block">
              <div class="flex items-center justify-between mb-4">
                <h3 class="font-black text-gray-900 text-foreground tracking-tight">More Videos</h3>
                <a href="/videos" class="text-primary text-xs font-semibold hover:underline">See all</a>
              </div>
              <div class="space-y-4">
                {related.map((v) => {
                  const relThumb = `https://img.youtube.com/vi/${v.youtubeId}/hqdefault.jpg`;
                  return (
                    <a
                      href={`/videos/${v.slug}`}
                      class="group flex gap-4 items-start bg-white  border border-gray-200  hover:border-primary/40 hover:shadow-md rounded-2xl p-4 transition-all duration-200"
                    >
                      <div class="relative w-28 shrink-0 aspect-video rounded-xl overflow-hidden bg-gray-100 ">
                        <img src={relThumb} alt={v.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                        <div class="absolute inset-0 bg-black/25 flex items-center justify-center">
                          <svg class="w-4 h-4 text-foreground fill-white" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                        </div>
                        <div class="absolute bottom-1 right-1 bg-black/80 text-foreground text-[10px] font-mono px-1.5 py-0.5 rounded">{v.durationDisplay}</div>
                      </div>
                      <div class="flex-1 min-w-0">
                        <h4 class="text-sm font-bold text-gray-900 text-foreground group-hover:text-primary transition-colors leading-snug line-clamp-2 mb-1">{v.title}</h4>
                        <span class="text-xs text-gray-500 flex items-center gap-1">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                          {v.durationDisplay}
                        </span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          )}

          <!-- Video info card -->
          <div class="bg-white  border border-gray-200  rounded-2xl p-5">
            <h4 class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">Video Details</h4>
            <div class="space-y-2.5 text-sm">
              {[
                { label: 'Channel', value: 'MicroManaged Media' },
                { label: 'Category', value: video.category },
                { label: 'Duration', value: video.durationDisplay },
                { label: 'Published', value: uploadFormatted },
              ].map((row, i, arr) => (
                <div class={`flex justify-between ${i < arr.length - 1 ? 'border-b border-gray-100  pb-2' : ''}`}>
                  <span class="text-gray-500">{row.label}</span>
                  <span class="font-semibold text-gray-900 text-foreground text-xs text-right">{row.value}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </aside>
    </div>
  </div>

  <Footer />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blogPosts';

const title = "The MicroManaged Media Blog | Contractor Marketing Insights";
const description = "Practical strategies for HVAC, plumbing, roofing, and electrical contractors who want more calls, more leads, and more booked jobs.";
const canonicalPath = "/blog";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://micromanagedmedia.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://micromanagedmedia.com/blog" }
  ]
};

const getCategoryColors = (category: string) => {
  switch (category) {
    case "Lead Generation": return "bg-primary/10 text-primary";
    case "Call Tracking": return "bg-accent/10 text-accent";
    case "Google Maps": return "bg-primary/10 text-primary";
    case "Reviews": return "bg-accent/10 text-accent";
    case "AI & Automation": return "bg-primary/10 text-primary";
    case "Website Design": return "bg-accent/10 text-accent";
    default: return "bg-primary/10 text-primary";
  }
};

const featuredPost = blogPosts[0];
const remainingPosts = blogPosts.slice(1);
---

<Layout title={title} description={description} canonicalPath={canonicalPath}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  {/* Hero Section */}
  <section class="bg-primary pt-32 pb-20 relative overflow-hidden">
    <div class="absolute w-[800px] h-[800px] bg-accent/10 rounded-full blur-[100px] top-[40%] left-[70%] transform -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-background to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <div class="mb-6 items-center flex gap-2 text-foreground/60 text-sm font-medium">
        <a href="/" class="hover:text-foreground transition-colors">Home</a>
        <span>&gt;</span>
        <span class="text-foreground">Blog</span>
      </div>

      <div class="inline-block px-4 py-1.5 rounded-full bg-accent/20 border border-accent/20 text-accent text-sm font-semibold uppercase tracking-widest mb-6">
        Contractor Marketing Insights
      </div>

      <h1 class="text-4xl md:text-6xl font-black text-foreground tracking-tight leading-tight mb-6">
        Contractor Marketing<br/><span class="text-accent">Insights Blog</span>
      </h1>
      
      <p class="text-foreground/70 text-xl max-w-2xl leading-relaxed">
        Practical strategies for HVAC, plumbing, roofing, and electrical contractors who want more calls, more leads, and more booked jobs.
      </p>
    </div>
  </section>

  {/* Main Content */}
  <section class="py-16 md:py-24 bg-background relative z-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      
      {/* Featured Post */}
      <h2 class="text-xs font-bold uppercase tracking-widest text-accent mb-4">Featured Post</h2>
      <a href={`/blog/${featuredPost.slug}`} class="block group mb-16">
        <article class="bg-card border border-border group-hover:border-accent/40 group-hover:shadow-xl rounded-2xl p-8 md:p-10 transition-all duration-300">
          <div class="flex items-center gap-4 mb-6">
            <span class={`text-xs font-bold px-3 py-1 rounded-full ${getCategoryColors(featuredPost.category)}`}>
              {featuredPost.category}
            </span>
            <span class="text-muted-foreground text-sm">{featuredPost.date}</span>
            <span class="text-muted-foreground text-sm hidden sm:inline">•</span>
            <span class="text-muted-foreground text-sm hidden sm:inline">{featuredPost.readTime}</span>
          </div>
          <h2 class="text-2xl md:text-3xl font-black text-foreground group-hover:text-primary tracking-tight mb-4 transition-colors">
            {featuredPost.title}
          </h2>
          <p class="text-muted-foreground text-lg leading-relaxed mb-6 max-w-3xl">
            {featuredPost.excerpt}
          </p>
          <span class="text-accent font-semibold flex items-center gap-2 group-hover:translate-x-1 transition-transform">
            Read article &rarr;
          </span>
        </article>
      </a>

      {/* Post Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {remainingPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="block group">
            <article class="bg-card border border-border group-hover:border-accent/40 group-hover:shadow-lg rounded-2xl p-7 transition-all duration-300 h-full flex flex-col">
              <div class="flex items-center gap-3 mb-5">
                <span class={`text-xs font-bold px-3 py-1 rounded-full ${getCategoryColors(post.category)}`}>
                  {post.category}
                </span>
                <span class="text-muted-foreground text-sm">{post.date}</span>
              </div>
              <h3 class="text-lg font-black text-foreground group-hover:text-primary tracking-tight mb-3 transition-colors">
                {post.title}
              </h3>
              <p class="text-muted-foreground text-sm line-clamp-3 mb-6 flex-grow">
                {post.excerpt}
              </p>
              <div class="flex items-center justify-between mt-auto">
                <span class="text-muted-foreground text-sm font-medium">{post.readTime}</span>
                <span class="text-accent font-semibold flex items-center gap-1 group-hover:translate-x-1 transition-transform">
                  Read &rarr;
                </span>
              </div>
            </article>
          </a>
        ))}
      </div>

      {/* CTA Banner */}
      <div class="bg-primary rounded-2xl p-10 text-center mt-16 md:mt-24 shadow-2xl relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('/noise.png')] opacity-5 mix-blend-overlay pointer-events-none"></div>
        <div class="relative z-10">
          <h3 class="text-2xl md:text-3xl font-black text-white mb-4">Ready to put these ideas to work?</h3>
          <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">
            Let's talk about what a complete lead generation system looks like for your business.
          </p>
          <a href="/#contact" class="inline-block bg-white hover:bg-gray-100 text-primary font-bold px-8 py-3.5 rounded-full transition-colors shadow-lg">
            Get a Free Strategy Call &rarr;
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>

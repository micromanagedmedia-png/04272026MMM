---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { trades, tradesBySlug } from '../../data/trades';

export async function getStaticPaths() {
  return trades.map((trade) => ({
    params: { slug: trade.slug },
    props: { trade },
  }));
}

const { trade } = Astro.props;

const APP_URL = 'https://micromanagedmedia.com';
const BOOK_URL = 'https://calendar.app.google/RUTjw3N7Afe95Tkk8';

// Service icon SVG paths
const serviceIconPaths: Record<string, string> = {
  'Google PPC':     'M23 6l-9.5 9.5-5-5L1 18M17 6h6v6',
  'Bing PPC':       'M18 20V10M12 20V4M6 20v-6',
  'Website Design': 'M12 2a10 10 0 100 20A10 10 0 0012 2zm0 0c-2.76 3.63-4 7.27-4 10s1.24 6.37 4 10m0-20c2.76 3.63 4 7.27 4 10s-1.24 6.37-4 10M2.05 12H22',
  'Call Tracking':  'M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z',
  'CRM Integration':'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  'AI Automation':  'M13 10V3L4 14h7v7l9-11h-7z',
};

const serviceLinks: Record<string, string> = {
  'Google PPC':     '/services/google-ppc',
  'Bing PPC':       '/services/bing-ppc',
  'Website Design': '/services/website-design',
  'Call Tracking':  '/services/call-tracking',
  'CRM Integration':'/services/crm-implementation',
  'AI Automation':  '/services/ai-automation',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${trade.name} PPC & Digital Marketing`,
  description: trade.tagline,
  provider: {
    '@type': 'LocalBusiness',
    name: 'MicroManaged Media',
    url: APP_URL,
  },
  areaServed: { '@type': 'Country', name: 'United States' },
  keywords: trade.keywords.join(', '),
};
---

<Layout
  title={`${trade.name} PPC & Digital Marketing | MicroManaged Media`}
  description={trade.tagline}
  canonical={`${APP_URL}/industries/${trade.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <Navbar />

  <!-- Hero -->
  <section class="relative bg-[#0a1628] pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 30% 50%, hsl(196 94% 40%) 0%, transparent 55%);"></div>
    <div class="container mx-auto px-6 relative z-10">
      <Breadcrumb
        items={[{ label: 'Industries', href: '/industries' }, { label: trade.name }]}
        variant="dark"
        class="mb-8"
      />
      <div class="max-w-3xl">
        <span class="text-cyan-400 text-sm font-semibold uppercase tracking-widest">Industry Specialization</span>
        <h1 class="text-4xl md:text-6xl font-black text-white mt-3 mb-5 tracking-tight leading-tight">
          PPC & Digital Marketing for<br />
          <span class="text-cyan-400">{trade.name}</span>
        </h1>
        <p class="text-white/70 text-xl leading-relaxed max-w-2xl">{trade.tagline}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/#contact" class="inline-flex items-center gap-2 bg-cyan-400 hover:bg-cyan-300 text-gray-900 font-bold px-8 py-3.5 rounded-full transition-colors">
            Get a Free Consultation
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/services/google-ppc" class="inline-flex items-center gap-2 text-white border border-white/20 hover:bg-white/10 rounded-full px-8 py-3.5 font-semibold transition-colors">
            View Google PPC Service
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white dark:from-gray-950 to-transparent"></div>
  </section>

  <!-- Stats -->
  <section class="bg-gray-50 dark:bg-gray-900/40 border-b border-gray-200 dark:border-gray-700">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-200 dark:divide-gray-700">
        {trade.stats.map((s) => (
          <div class="py-6 px-4 text-center">
            <div class="text-2xl md:text-3xl font-black text-blue-900 dark:text-blue-400">{s.value}</div>
            <div class="text-xs text-gray-500 mt-1 uppercase tracking-wider">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white mb-6 tracking-tight">
        Digital Marketing Built for <span class="text-blue-900 dark:text-blue-400">{trade.shortName} Businesses</span>
      </h2>
      <p class="text-gray-500 dark:text-gray-400 text-[1.0625rem] leading-relaxed">{trade.heroDescription}</p>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900/20 border-y border-gray-200 dark:border-gray-700">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white tracking-tight mb-3">
            Problems We <span class="text-blue-900 dark:text-blue-400">Solve for {trade.shortName} Companies</span>
          </h2>
          <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
            We've managed campaigns for {trade.shortName.toLowerCase()} businesses across 50+ markets. We know exactly where the budget gets wasted — and how to fix it.
          </p>
        </div>
        <div class="grid md:grid-cols-2 gap-5">
          {trade.painPoints.map((pt) => (
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl p-6 flex items-start gap-4 hover:border-cyan-400/30 hover:shadow-md transition-all duration-300">
              <div class="w-9 h-9 rounded-xl bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-blue-900 dark:text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 dark:text-white mb-1.5 leading-snug">{pt.title}</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">{pt.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <span class="text-cyan-500 text-sm font-semibold uppercase tracking-widest">Full-Service Digital Marketing</span>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white mt-2 mb-3 tracking-tight">
            Everything a <span class="text-blue-900 dark:text-blue-400">{trade.shortName} Company Needs</span> to Dominate Online
          </h2>
          <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
            From paid search to call tracking to AI automation — every service we offer is tailored to how {trade.shortName.toLowerCase()} businesses actually operate.
          </p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {trade.services.map((svc) => {
            const iconPath = serviceIconPaths[svc.name] ?? 'M9 5l7 7-7 7';
            const href = serviceLinks[svc.name] ?? '/';
            return (
              <a
                href={href}
                class="group flex flex-col h-full bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl p-6 hover:border-cyan-400/40 hover:shadow-md transition-all duration-300"
              >
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-900/20 group-hover:bg-cyan-50 dark:group-hover:bg-cyan-900/10 flex items-center justify-center text-blue-900 dark:text-blue-400 group-hover:text-cyan-500 transition-colors shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                      <path d={iconPath} />
                    </svg>
                  </div>
                  <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-cyan-500 transition-colors">{svc.name}</h3>
                </div>
                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed flex-1">{svc.desc}</p>
                <div class="flex items-center gap-1 mt-4 text-cyan-500 text-xs font-semibold">
                  Learn more
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Body sections -->
  <section class="py-20 bg-gray-50 dark:bg-gray-900/20 border-t border-gray-200 dark:border-gray-700">
    <div class="container mx-auto px-6 max-w-4xl space-y-14">
      {trade.seoBody.map((section) => (
        <div>
          <h2 class="text-2xl md:text-3xl font-black text-gray-900 dark:text-white mb-4 tracking-tight">{section.heading}</h2>
          <p class="text-gray-500 dark:text-gray-400 text-[1.0625rem] leading-relaxed">{section.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[#0a1628] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(ellipse at 50% 100%, hsl(196 94% 40%) 0%, transparent 60%);"></div>
    <div class="container mx-auto px-6 text-center max-w-2xl relative">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/80 text-xs font-semibold px-4 py-2 rounded-full mb-6 uppercase tracking-widest">
        <svg class="w-3 h-3 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Free Consultation — No Obligation
      </div>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight">{trade.ctaHeading}</h2>
      <p class="text-white/60 text-lg mb-8 leading-relaxed">
        With 20+ years of experience and deep knowledge of the {trade.shortName.toLowerCase()} industry, MicroManaged Media delivers campaigns that move the needle on your bottom line.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-cyan-400 hover:bg-cyan-300 text-gray-900 font-bold px-10 py-4 rounded-full transition-colors">
          Get My Free Strategy Session
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
        <a href="/industries" class="inline-flex items-center justify-center gap-2 text-white border border-white/20 hover:bg-white/10 rounded-full px-10 py-4 font-semibold transition-colors">
          View All Industries
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-white/40 text-xs uppercase tracking-widest">
        <span>✓ 20+ Years Experience</span>
        <span>✓ 50 U.S. Markets</span>
        <span>✓ No Long-Term Contracts</span>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

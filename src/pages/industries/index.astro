---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import { trades } from '../../data/trades';

const APP_URL = 'https://micromanagedmedia.com';
const BOOK_URL = 'https://calendar.app.google/RUTjw3N7Afe95Tkk8';

const highlights = [
  { value: '12', label: 'Trade Specializations' },
  { value: '50', label: 'U.S. Markets Served' },
  { value: '20+', label: 'Years Experience' },
  { value: '6.2x', label: 'Average ROAS' },
];

// Icon SVG paths keyed by trade slug
const tradeIconPaths: Record<string, string> = {
  'hvac':               'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  'plumbing':           'M12 3v1m0 16v1M4.22 4.22l.707.707M18.364 18.364l.707.707M1 12h1m20 0h1M4.22 19.78l.707-.707M18.364 5.636l.707-.707',
  'roofing':            'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
  'electricians':       'M13 10V3L4 14h7v7l9-11h-7z',
  'fence-contractors':  'M4 4h16M4 12h16M4 20h16',
  'remodeling':         'M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z',
  'general-contractors':'M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z',
  'landscaping':        'M12 3c-4.97 0-9 3.185-9 7.115 0 2.557 1.522 4.82 3.889 6.154V21l2.666-1.333L12 21l2.444-1.333L17.11 21v-4.73C19.478 14.934 21 12.672 21 10.115 21 6.185 16.97 3 12 3z',
  'concrete-masonry':   'M19 14l-7 7m0 0l-7-7m7 7V3',
  'painting':           'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485',
  'pest-control':       'M12 9v4m0 4h.01M5.07 19H19a2 2 0 001.75-2.98L13.75 4a2 2 0 00-3.5 0L3.25 16.02A2 2 0 005.07 19z',
  'garage-doors':       'M5 3a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2H5zm0 2h14v10H5V5zm3 12h8',
};
---

<Layout
  title="Industries We Serve | PPC for Contractors | MicroManaged Media"
  description="MicroManaged Media specializes exclusively in blue collar service businesses — HVAC, plumbing, roofing, electrical, and more. Trade-specific PPC campaigns across 50 U.S. markets."
  canonical={`${APP_URL}/industries`}
>
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-[#0a1628] pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 70% 40%, hsl(196 94% 40%) 0%, transparent 55%);"></div>
    <div class="container mx-auto px-6 relative z-10">
      <Breadcrumb items={[{ label: 'Industries' }]} variant="dark" class="mb-8" />
      <div class="max-w-3xl">
        <span class="text-cyan-400 text-sm font-semibold uppercase tracking-widest">Industries We Serve</span>
        <h1 class="text-4xl md:text-6xl font-black text-white mt-3 mb-5 tracking-tight leading-tight">
          PPC & Digital Marketing<br />
          <span class="text-cyan-400">Built for the Trades</span>
        </h1>
        <p class="text-white/70 text-xl leading-relaxed max-w-2xl">
          MicroManaged Media specializes exclusively in blue collar service businesses — HVAC, plumbing, roofing, electrical, and more. We understand your trade, your customers, and what it takes to fill your schedule with the right jobs.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/#contact" class="inline-flex items-center gap-2 bg-cyan-400 hover:bg-cyan-300 text-gray-900 font-bold px-8 py-3.5 rounded-full transition-colors">
            Get a Free Consultation
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/services/google-ppc" class="inline-flex items-center gap-2 text-white border border-white/20 hover:bg-white/10 rounded-full px-8 py-3.5 font-semibold transition-colors">
            View Google PPC Service
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white dark:from-gray-950 to-transparent"></div>
  </section>

  <!-- Stats -->
  <section class="bg-gray-50 dark:bg-gray-900/40 border-b border-gray-200 dark:border-gray-700">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-200 dark:divide-gray-700">
        {highlights.map((s) => (
          <div class="py-6 px-4 text-center">
            <div class="text-2xl md:text-3xl font-black text-blue-900 dark:text-blue-400">{s.value}</div>
            <div class="text-xs text-gray-500 mt-1 uppercase tracking-wider">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white mb-6 tracking-tight">
        We Only Work With <span class="text-blue-900 dark:text-blue-400">Local Service Contractors</span>
      </h2>
      <div class="space-y-4 text-gray-500 dark:text-gray-400 text-[1.0625rem] leading-relaxed">
        <p>Most digital marketing agencies claim to serve everyone. We don't. MicroManaged Media is built exclusively for blue collar service businesses — the contractors, tradespeople, and home service professionals who keep homes and businesses running. We understand the seasonal swings, the tight margins, the high-urgency calls, and the local competition that define your business — because we've been managing campaigns for these exact industries for over 20 years.</p>
        <p>When a homeowner's AC dies in July, they're calling the first HVAC company that shows up on Google. When they discover a leak under the sink, they need a plumber now. When hail hits their roof, they're searching for a roofer before the storm has even passed. These moments of urgency are when your digital marketing either pays off or fails you — and we build campaigns that ensure you capture every one of them.</p>
        <p>Select your trade below to see how MicroManaged Media's services are specifically tailored to the way your business works, your customers think, and your market operates.</p>
      </div>
    </div>
  </section>

  <!-- Trade Grid -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900/20 border-t border-gray-200 dark:border-gray-700">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white tracking-tight mb-3">
          Select Your <span class="text-blue-900 dark:text-blue-400">Trade</span>
        </h2>
        <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
          Click your industry to see trade-specific strategies, pain points, and how every MicroManaged Media service is built for your business.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 max-w-6xl mx-auto">
        {trades.map((trade) => {
          const iconPath = tradeIconPaths[trade.slug] ?? 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0';
          return (
            <a
              href={`/industries/${trade.slug}`}
              class="group flex flex-col h-full bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 hover:border-cyan-400/40 hover:shadow-lg rounded-2xl p-6 transition-all duration-300"
            >
              <div class="w-12 h-12 rounded-xl bg-blue-50 dark:bg-blue-900/20 group-hover:bg-cyan-50 dark:group-hover:bg-cyan-900/10 flex items-center justify-center text-blue-900 dark:text-blue-400 group-hover:text-cyan-500 transition-colors mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d={iconPath} />
                </svg>
              </div>
              <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-cyan-500 transition-colors mb-2 leading-snug">
                {trade.name}
              </h3>
              <p class="text-gray-500 dark:text-gray-400 text-xs leading-relaxed flex-1 line-clamp-3">
                {trade.heroDescription.slice(0, 120)}...
              </p>
              <div class="flex items-center gap-1 mt-4 text-cyan-500 text-xs font-semibold">
                View strategies
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Why specialists matter -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white mb-6 tracking-tight">
        Why Trade Specialization <span class="text-blue-900 dark:text-blue-400">Changes Your Results</span>
      </h2>
      <div class="space-y-4 text-gray-500 dark:text-gray-400 text-[1.0625rem] leading-relaxed">
        <p>A marketing agency that works with restaurants, law firms, e-commerce stores, and HVAC companies doesn't truly understand any of them. They apply generic strategies and hope for the best. We work exclusively with local contractor businesses — which means we've seen every keyword strategy, every seasonal pattern, every competitive dynamic, and every market condition that affects your industry.</p>
        <p>Trade specialization means we know which keywords produce emergency service calls vs. price shoppers. We know that roofing budgets need to surge immediately after a hail event. We know that HVAC campaigns need different structures for cooling season, heating season, and shoulder season. We know that fence contractor leads have a 4–6 week close cycle while plumbing emergency calls close in 15 minutes. These nuances — invisible to generalist agencies — are built into every campaign we manage from day one.</p>
        <p>The result is faster ramp times, lower cost per lead, and campaigns that improve continuously because our optimization decisions are informed by deep industry knowledge, not just platform data.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[#0a1628] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(ellipse at 50% 100%, hsl(196 94% 40%) 0%, transparent 60%);"></div>
    <div class="container mx-auto px-6 text-center max-w-2xl relative">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 text-white/80 text-xs font-semibold px-4 py-2 rounded-full mb-6 uppercase tracking-widest">
        <svg class="w-3 h-3 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Free Consultation — No Obligation
      </div>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight">
        Ready to Grow Your<br />Contracting Business?
      </h2>
      <p class="text-white/60 text-lg mb-8 leading-relaxed">
        Tell us your trade and your market and we'll build a custom strategy showing you exactly how to dominate local search.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="inline-flex items-center justify-center gap-2 bg-cyan-400 hover:bg-cyan-300 text-gray-900 font-bold px-10 py-4 rounded-full transition-colors">
          Get My Free Strategy Session
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
        <a href="/services/google-ppc" class="inline-flex items-center justify-center gap-2 text-white border border-white/20 hover:bg-white/10 rounded-full px-10 py-4 font-semibold transition-colors">
          View Google PPC
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-white/40 text-xs uppercase tracking-widest">
        <span>✓ Blue Collar Specialists</span>
        <span>✓ 50 U.S. Markets</span>
        <span>✓ 20+ Years Experience</span>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

---
// Contact.astro
---

<section id="contact" class="py-24 bg-background relative border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h3 class="text-primary font-bold uppercase tracking-widest text-sm mb-3">Get In Touch</h3>
      <h2 class="text-4xl md:text-5xl font-black text-foreground mb-6 tracking-tight">Let's Build Something <span class="text-primary">Remarkable</span></h2>
      <p class="text-lg text-slate-600 leading-relaxed">Ready to stop leaving growth on the table? Tell us about your project and we'll craft a custom strategy.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
      
      <!-- Left Panel -->
      <div class="lg:col-span-2 flex flex-col gap-6">
        
        <!-- Contact Info Card -->
        <div class="bg-white/10 border border-border rounded-2xl p-8 backdrop-blur-sm">
          <h3 class="text-xl font-bold text-foreground mb-6">Contact Information</h3>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/5 border border-border flex items-center justify-center flex-shrink-0 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 .8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z"/><path d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10"/></svg>
              </div>
              <div>
                <p class="text-sm text-slate-600 font-semibold mb-1 uppercase tracking-wider">Email</p>
                <a href="mailto:info@micromanagedmedia.com" class="text-foreground hover:text-primary font-medium transition-colors">Click Here</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/5 border border-border flex items-center justify-center flex-shrink-0 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <p class="text-sm text-slate-600 font-semibold mb-1 uppercase tracking-wider">Phone</p>
                <a href="tel:+12517650333" class="text-foreground hover:text-primary font-medium transition-colors">+1 (251) 765-0333</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/5 border border-border flex items-center justify-center flex-shrink-0 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="text-sm text-slate-600 font-semibold mb-1 uppercase tracking-wider">Office</p>
                <p class="text-foreground font-medium">Foley, AL 36535</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Book a Time Card -->
        <a href="https://calendar.app.google/RUTjw3N7Afe95Tkk8" target="_blank" rel="noopener noreferrer" class="bg-primary rounded-2xl p-6 hover:bg-amber-600 transition-colors group block">
          <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center text-[#020617] mb-4 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#020617] mb-2 tracking-tight">Book a Time to Talk</h3>
          <p class="text-[#020617]/75 font-medium text-sm leading-relaxed">Pick a slot on Bob's calendar &mdash; free, no obligation.</p>
        </a>

        <!-- Response Time Box -->
        <div class="bg-white/5 border border-border rounded-2xl p-6 backdrop-blur-sm">
          <p class="text-primary font-semibold mb-2 flex items-center gap-2">
            <span>⚡</span> Response Time
          </p>
          <p class="text-slate-600 text-sm leading-relaxed">We respond to all inquiries within 24 business hours. For urgent matters, call us directly.</p>
        </div>

      </div>

      <!-- Right Panel: Form -->
      <div class="lg:col-span-3 bg-white/5 border border-border rounded-2xl p-8 md:p-10 backdrop-blur-sm relative overflow-hidden" id="contact-form-container">
        
        <form id="main-contact-form" class="space-y-6" onsubmit="event.preventDefault(); window.handleContactSubmit();">
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="block text-sm font-semibold text-slate-700">Full Name*</label>
              <input type="text" id="name" name="name" required class="w-full bg-background border border-border rounded-xl px-4 py-3 text-foreground placeholder-slate-500 outline-none focus:border-primary/50 focus:ring-1 focus:ring-amber-500/50 transition-all font-medium" placeholder="John Doe">
            </div>
            <div class="space-y-2">
              <label for="email" class="block text-sm font-semibold text-slate-700">Email Address*</label>
              <input type="email" id="email" name="email" required class="w-full bg-background border border-border rounded-xl px-4 py-3 text-foreground placeholder-slate-500 outline-none focus:border-primary/50 focus:ring-1 focus:ring-amber-500/50 transition-all font-medium" placeholder="john@example.com">
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="phone" class="block text-sm font-semibold text-slate-700">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="w-full bg-background border border-border rounded-xl px-4 py-3 text-foreground placeholder-slate-500 outline-none focus:border-primary/50 focus:ring-1 focus:ring-amber-500/50 transition-all font-medium" placeholder="(555) 123-4567">
            </div>
            <div class="space-y-2">
              <label for="company" class="block text-sm font-semibold text-slate-700">Company</label>
              <input type="text" id="company" name="company" class="w-full bg-background border border-border rounded-xl px-4 py-3 text-foreground placeholder-slate-500 outline-none focus:border-primary/50 focus:ring-1 focus:ring-amber-500/50 transition-all font-medium" placeholder="Business Name">
            </div>
          </div>

          <div class="space-y-2">
            <label for="service" class="block text-sm font-semibold text-slate-700">Service Interested In</label>
            <div class="relative">
              <select id="service" name="service" class="w-full bg-background border border-border rounded-xl px-4 py-3 text-foreground appearance-none outline-none focus:border-primary/50 focus:ring-1 focus:ring-amber-500/50 transition-all font-medium cursor-pointer">
                <option value="" disabled selected>Select an option...</option>
                <option value="Answer My Calls 24/7">Answer My Calls 24/7</option>
                <option value="Get More Leads with Google Ads">Get More Leads with Google Ads</option>
                <option value="Track Every Call & Lead">Track Every Call &amp; Lead</option>
                <option value="Capture Leads with AI Chatbot">Capture Leads with AI Chatbot</option>
                <option value="Build My Contractor Website">Build My Contractor Website</option>
                <option value="Improve My Google Maps Presence">Improve My Google Maps Presence</option>
                <option value="Get More 5-Star Reviews">Get More 5-Star Reviews</option>
              </select>
              <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>

          <div class="space-y-2">
            <label for="message" class="block text-sm font-semibold text-slate-700">Tell Us About Your Project*</label>
            <textarea id="message" name="message" rows="5" required class="w-full bg-background border border-border rounded-xl px-4 py-3 text-foreground placeholder-slate-500 outline-none focus:border-primary/50 focus:ring-1 focus:ring-amber-500/50 transition-all font-medium resize-none" placeholder="What are your main goals and challenges right now?"></textarea>
          </div>

          <button type="submit" class="w-full h-14 bg-primary hover:bg-amber-600 text-white font-black rounded-xl transition-transform hover:scale-[0.98] flex items-center justify-center gap-2 text-lg shadow-xl shadow-primary/20 active:scale-95">
            Send Message
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          </button>
        </form>

        <!-- Success State -->
        <div id="contact-success" class="hidden absolute inset-0 bg-background z-10 flex flex-col items-center justify-center p-8 text-center bg-opacity-95 backdrop-blur-sm">
          <div class="w-20 h-20 rounded-full bg-green-500/20 text-green-500 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          </div>
          <h3 class="text-3xl font-black text-foreground mb-4">Message Received!</h3>
          <p class="text-slate-600 mb-8 max-w-md">Thanks for reaching out. Our team will be in touch with you within 24 hours.</p>
          <button type="button" onclick="window.resetContactForm()" class="px-8 py-3 bg-white/10 hover:bg-white/20 border border-slate-300 text-foreground font-bold rounded-lg transition-colors">
            Send Another Message
          </button>
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  window.handleContactSubmit = function() {
    const form = document.getElementById('main-contact-form') as HTMLFormElement;
    const success = document.getElementById('contact-success');
    
    // Simulate API call delay
    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-[#020617]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Sending...';
    btn.setAttribute('disabled', 'true');
    
    setTimeout(() => {
      form.reset();
      btn.innerHTML = originalText;
      btn.removeAttribute('disabled');
      success.classList.remove('hidden');
    }, 800);
  };

  window.resetContactForm = function() {
    document.getElementById('contact-success').classList.add('hidden');
  };
</script>

---
// src/components/ServicePageLayout.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  subtitle: string;
  tagline: string;
  iconSvg: string;
  heroStats: { value: string; label: string }[];
  benefits: string[];
  sections: { heading: string; body: string }[];
  ctaHeading: string;
  faqs: { question: string; answer: string }[];
  relatedServices: { title: string; desc: string; href: string }[];
  canonicalPath: string;
  metaTitle?: string;
  metaDescription?: string;
}

const {
  title,
  subtitle,
  tagline,
  iconSvg,
  heroStats,
  benefits,
  sections,
  ctaHeading,
  faqs,
  relatedServices,
  canonicalPath,
  metaTitle,
  metaDescription
} = Astro.props as Props;

const finalMetaTitle = metaTitle ?? `${title} | MicroManaged Media`;
const finalMetaDescription = metaDescription ?? tagline;

const schemaData = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;
const schemaText = schemaData ? JSON.stringify(schemaData) : '';
---

<Layout title={finalMetaTitle} description={finalMetaDescription}>
  {schemaData && <script type="application/ld+json" set:html={schemaText} />}
  
  <Navbar />
  
  <main class="bg-background min-h-screen">
    <!-- Hero -->
    <section class="bg-background pt-32 pb-24 relative overflow-hidden">
      <!-- Radial gradient overlay -->
      <div class="absolute inset-0 opacity-10 pointer-events-none -z-10" style="background: radial-gradient(circle at 30% 50%, var(--color-accent) 0%, transparent 60%);"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-foreground/60 text-sm font-medium mb-8">
          <a href="/" class="hover:text-foreground transition-colors">Home</a>
          <span>&gt;</span>
          <span>Services</span>
          <span>&gt;</span>
          <span class="text-accent cursor-default truncate">{title}</span>
        </div>

        <div class="max-w-4xl">
          <!-- Icon box and subtitle -->
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-accent/20 border border-accent/30 flex items-center justify-center text-accent flex-shrink-0" set:html={iconSvg}></div>
            <span class="text-accent text-sm font-semibold uppercase tracking-widest">{subtitle}</span>
          </div>

          <!-- Hero Text -->
          <h1 class="text-4xl md:text-6xl font-black text-foreground mt-3 mb-5 tracking-tight leading-tight">
            {title}
          </h1>
          <p class="text-foreground/70 text-xl leading-relaxed max-w-2xl">
            {tagline}
          </p>

          <!-- CTA Buttons -->
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="https://calendar.app.google/RUTjw3N7Afe95Tkk8" target="_blank" rel="noopener noreferrer" class="bg-cyan-400 hover:bg-cyan-300 text-gray-900 rounded-full px-8 h-12 font-semibold flex items-center justify-center transition-colors">
              📅 Book a Time to Talk
            </a>
            <a href="/#contact" class="bg-cyan-600 hover:bg-cyan-500 text-white rounded-full px-8 h-12 font-semibold flex items-center justify-center transition-colors">
              Get a Free Consultation &rarr;
            </a>
          </div>
        </div>
      </div>
      <!-- Bottom gradient -->
      <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-background to-transparent pointer-events-none z-10"></div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-muted/40 border-b border-border relative z-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-border">
          {heroStats.map((stat) => (
            <div class="py-6 px-4 text-center">
              <div class="text-2xl md:text-3xl font-black text-primary">{stat.value}</div>
              <div class="text-xs text-muted-foreground mt-1 uppercase tracking-wider">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-20 relative z-20">
      <div class="grid lg:grid-cols-3 gap-12 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Left Column -->
        <div class="lg:col-span-2 space-y-10">
          {sections.map((section) => (
            <div>
              <h2 class="text-2xl md:text-3xl font-black text-foreground mb-4 tracking-tight">{section.heading}</h2>
              <div class="text-muted-foreground leading-relaxed space-y-3 text-[1.0625rem]" set:html={section.body}></div>
            </div>
          ))}
        </div>

        <!-- Right sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Key Benefits Card -->
            <div class="bg-primary rounded-2xl p-7 text-white">
              <h3 class="font-black text-xl mb-5">Key Benefits</h3>
              <ul class="space-y-4">
                {benefits.map(benefit => (
                  <li class="flex items-start gap-3 text-base">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-white w-5 h-5 shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-white font-medium">{benefit}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Ready to Get Started Card -->
            <div class="bg-accent rounded-2xl p-7 text-white mt-6">
              <h3 class="font-black text-xl mb-4">Ready to Get Started?</h3>
              <p class="text-white text-base font-medium mb-6">Talk to our specialists and get a custom strategy built around your business goals.</p>
              <a href="/#contact" class="flex items-center justify-center w-full bg-white text-accent hover:bg-white/90 rounded-xl font-bold py-3.5 text-lg">
                Book Free Consultation
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    {faqs && faqs.length > 0 && (
      <section class="py-20 border-t border-border bg-muted/20 relative z-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-12">
            <h3 class="text-primary text-sm font-semibold uppercase tracking-widest mb-2">Frequently Asked Questions</h3>
            <h2 class="text-3xl md:text-4xl font-black text-foreground mt-2 tracking-tight">Straight answers to the questions business owners ask us most.</h2>
          </div>

          <div class="space-y-3 max-w-3xl mx-auto service-faqs">
            {faqs.map((faq, index) => (
              <div class="faq-accordion-item border border-border rounded-2xl overflow-hidden group" data-open="false">
                <button class="faq-accordion-toggle w-full flex items-center justify-between gap-4 px-6 py-5 text-left bg-card hover:bg-muted/40 transition-colors focus:outline-none" aria-expanded="false" aria-controls={`faq-answer-${index}`}>
                  <span class="font-bold text-foreground text-[1rem] leading-snug">{faq.question}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary shrink-0 transition-transform group-data-[open=true]:rotate-180 faq-chevron"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="faq-accordion-content hidden px-6 pb-5 pt-1 text-muted-foreground leading-relaxed text-[0.9375rem] border-t border-border bg-muted/20" id={`faq-answer-${index}`}>
                  <p>{faq.answer}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Related Services -->
    {relatedServices && relatedServices.length > 0 && (
      <section class="py-20 border-t border-border relative z-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h3 class="text-accent text-sm font-semibold uppercase tracking-widest mb-2">Related Services</h3>
            <h2 class="text-3xl md:text-4xl font-black text-foreground mt-2 tracking-tight">Complete Your Lead System</h2>
            <p class="text-muted-foreground mt-3 text-base max-w-xl mx-auto">These services work together with this one &mdash; building a pipeline that captures, handles, and converts more leads.</p>
          </div>

          <div class="grid md:grid-cols-3 gap-6 mt-10">
            {relatedServices.map(srv => (
              <a href={srv.href} class="group bg-card border border-border hover:border-accent/40 hover:shadow-lg rounded-2xl p-7 flex flex-col h-full transition-all">
                <h3 class="font-bold text-foreground text-lg mb-2 group-hover:text-accent">{srv.title}</h3>
                <p class="text-muted-foreground text-sm leading-relaxed flex-1 mb-4">{srv.desc}</p>
                <span class="text-accent text-sm font-semibold">Explore this service &rarr;</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Bottom CTA -->
    <section class="bg-muted/30 border-t border-border py-20 text-center relative z-20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-black text-foreground mb-4 tracking-tight">{ctaHeading}</h2>
        <p class="text-muted-foreground text-lg mb-8 max-w-2xl mx-auto">With 20+ years of experience, MicroManaged Media delivers measurable results &mdash; not just promises.</p>
        <a href="/#contact" class="inline-block bg-primary hover:bg-primary/90 text-primary-foreground rounded-full px-10 py-4 font-bold transition-all">
          Start Your Campaign Today &rarr;
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const accordions = document.querySelectorAll('.faq-accordion-item');
    accordions.forEach(item => {
      const toggleBtn = item.querySelector('.faq-accordion-toggle');
      const content = item.querySelector('.faq-accordion-content');
      if (toggleBtn && content) {
        toggleBtn.addEventListener('click', () => {
          const isOpen = item.getAttribute('data-open') === 'true';
          
          accordions.forEach(other => {
            other.setAttribute('data-open', 'false');
            other.querySelector('.faq-accordion-toggle')?.setAttribute('aria-expanded', 'false');
            other.querySelector('.faq-accordion-content')?.classList.add('hidden');
          });

          if (!isOpen) {
            item.setAttribute('data-open', 'true');
            toggleBtn.setAttribute('aria-expanded', 'true');
            content.classList.remove('hidden');
          }
        });
      }
    });
  });
</script>

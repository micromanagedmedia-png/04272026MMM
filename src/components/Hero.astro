---
// Hero.astro
---

<section class="relative min-h-screen pt-24 pb-16 flex flex-col justify-center overflow-hidden">
  
  <!-- Backgrounds -->
  <div class="absolute inset-0 z-0">
    <picture>
      <source media="(max-width: 767px)" srcset="https://images.fillout.com/orgid-30300/flowpublicid-f4gvodhkuc/widgetid-default/vZdrAqwoao9kGekyfUB4cb/pasted-image-1775597453825.webp" />
      <img src="https://images.fillout.com/orgid-30300/flowpublicid-f4gvodhkuc/widgetid-default/oVNKccq4heFhtmgDHtbo5m/pasted-image-1775588115696.webp" alt="Service contractor at work" class="w-full h-full object-cover" />
    </picture>
    <!-- Overlay: Dark bg at 50% -->
    <div class="absolute inset-0 bg-slate-900/50 mix-blend-multiply"></div>
    <!-- Bottom gradient to match page bg -->
    <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-t from-[#020617] to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="max-w-4xl pt-12 md:pt-20">
      
        <!-- Top Badge -->
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-black/50 border border-slate-300 mb-8 backdrop-blur-sm">
        <span class="w-2.5 h-2.5 rounded-full bg-primary animate-pulse shadow-[0_0_8px_rgba(245,158,11,0.8)]"></span>
        <span class="text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] text-white">Lead Generation Systems for Service Contractors</span>
      </div>

      <!-- H1 Headline -->
      <h1 class="text-5xl sm:text-7xl font-black text-white leading-[0.95] tracking-tight mb-6 drop-shadow-lg">
        <span class="block mb-2">If the Phone</span>
        <span class="block text-cyan-400 mb-2">Isn't Ringing,</span>
        <span class="block">We Fix That.</span>
      </h1>

      <!-- P1 -->
      <p class="text-lg sm:text-xl text-slate-100 font-medium mb-6 leading-relaxed max-w-2xl drop-shadow-md">
        MicroManaged Media builds PPC campaigns, high-converting websites, and AI call-handling systems that generate consistent, trackable leads for HVAC, plumbing, roofing, and local service contractors.
      </p>

      <!-- P2 -->
      <p class="text-sm md:text-sm text-slate-300 mb-10 max-w-2xl leading-relaxed">
        We build 
        <a href="/get-more-leads" class="text-primary hover:text-white hover:opacity-100 underline decoration-primary/50 underline-offset-4 transition-colors">manual PPC campaigns for contractors</a>, 
        <a href="/answer-my-calls" class="text-primary hover:text-white hover:opacity-100 underline decoration-primary/50 underline-offset-4 transition-colors">AI answering services for contractors</a>, 
        <a href="/track-calls-leads" class="text-primary hover:text-white hover:opacity-100 underline decoration-primary/50 underline-offset-4 transition-colors">contractor lead generation systems</a>, and 
        <a href="/ai-chatbot" class="text-primary hover:text-white hover:opacity-100 underline decoration-primary/50 underline-offset-4 transition-colors">AI-powered integrations</a> 
        that keep your pipeline full.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row flex-wrap items-center gap-4 sm:gap-6 mb-16">
        <a href="https://calendar.app.google/RUTjw3N7Afe95Tkk8" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-10 py-5 bg-primary hover:bg-slate-800 text-white font-black rounded-full text-lg shadow-2xl shadow-primary/20 transition-transform focus:scale-95 text-center flex items-center justify-center gap-2 group">
          Book a Call
          <span class="inline-block group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a href="#contact" class="w-full sm:w-auto px-10 py-5 bg-cyan-500 hover:bg-cyan-600 text-white font-bold rounded-full text-lg shadow-2xl transition-transform focus:scale-95 text-center flex items-center justify-center gap-2 group border border-transparent">
          Get a Free Lead Gen Audit
        </a>
        <a href="#services" class="w-full sm:w-auto px-8 py-5 bg-cyan-600 hover:bg-cyan-700 text-white font-bold rounded-full text-lg shadow-2xl transition-all text-center flex items-center justify-center gap-3 border border-transparent">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          See How It Works
        </a>
      </div>

    </div>
  </div>

  <!-- Stats Bar -->
  <div class="relative z-10 w-full mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="w-full max-w-4xl mx-auto grid grid-cols-2 lg:grid-cols-4 gap-4 px-8 py-6 backdrop-blur-xl bg-white/5 border border-border rounded-t-2xl">
        <div class="text-center lg:border-r border-border last:border-r-0">
          <div class="text-2xl font-black text-primary">25+</div>
          <div class="text-[10px] uppercase font-semibold text-slate-600 tracking-wider mt-1">Years PPC Experience</div>
        </div>
        <div class="text-center lg:border-r border-border last:border-r-0">
          <div class="text-2xl font-black text-foreground">50</div>
          <div class="text-[10px] uppercase font-semibold text-slate-600 tracking-wider mt-1">U.S. Markets Served</div>
        </div>
        <div class="text-center lg:border-r border-border last:border-r-0">
          <div class="text-2xl font-black text-foreground">$5M+</div>
          <div class="text-[10px] uppercase font-semibold text-slate-600 tracking-wider mt-1">Ad Spend Managed</div>
        </div>
        <div class="text-center border-border last:border-r-0">
          <div class="text-2xl font-black text-foreground">6.2x</div>
          <div class="text-[10px] uppercase font-semibold text-slate-600 tracking-wider mt-1">Average ROAS</div>
        </div>
      </div>
    </div>
  </div>
</section>

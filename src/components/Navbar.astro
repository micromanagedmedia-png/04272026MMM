---
// Navbar.astro
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 backdrop-blur-md bg-background border-b border-border text-foreground">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo -->
      <a href="https://micromanagedmedia.com/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 bg-primary border-none text-white flex items-center justify-center font-bold text-xl rounded-md transition-colors group-hover:bg-accent group-hover:shadow-md">
          M
        </div>
        <div class="flex flex-col -gap-1">
          <span class="font-bold text-lg leading-tight transition-colors logo-text text-foreground">MicroManaged</span>
          <span class="text-primary font-bold text-lg leading-tight">Media</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8 font-medium">
        
        <div class="relative group h-20 flex items-center">
          <button class="flex items-center gap-1 hover:text-accent hover:opacity-80 transition-colors nav-link">
            Services
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          
          <div class="absolute top-20 left-1/2 -translate-x-1/2 w-72 bg-background/95 text-foreground backdrop-blur-xl shadow-xl shadow-slate-200 rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 border border-border overflow-hidden translate-y-2 group-hover:translate-y-0">
            <div class="flex flex-col text-sm">
              <a href="/get-more-leads" class="px-5 py-3 hover:bg-white/10 transition-colors border-b border-slate-100">PPC Advertising for Contractors</a>
              <a href="/track-calls-leads" class="px-5 py-3 hover:bg-white/10 transition-colors border-b border-slate-100">Lead Generation & Tracking</a>
              <a href="/answer-my-calls" class="px-5 py-3 hover:bg-white/10 transition-colors border-b border-slate-100">AI Answering Service</a>
              <a href="/ai-chatbot" class="px-5 py-3 hover:bg-white/10 transition-colors border-b border-slate-100">AI Chatbot Integration</a>
              <a href="/contractor-website" class="px-5 py-3 hover:bg-white/10 transition-colors border-b border-slate-100">Contractor Website Design</a>
              <a href="/google-maps" class="px-5 py-3 hover:bg-white/10 transition-colors border-b border-slate-100">Google Maps Optimization</a>
              <a href="/5-star-reviews" class="px-5 py-3 hover:bg-white/10 transition-colors">5-Star Review Generation</a>
            </div>
          </div>
        </div>

        <a href="/industries" class="hover:text-accent hover:opacity-80 transition-colors nav-link">Industries</a>
        <a href="/videos" class="hover:text-accent hover:opacity-80 transition-colors nav-link">Videos</a>
        <a href="/modern-web-blueprint" class="hover:text-accent hover:opacity-80 transition-colors nav-link">Blueprint</a>
        <a href="/#testimonials" class="hover:text-accent hover:opacity-80 transition-colors nav-link">Reviews</a>
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="tel:+12517650333" class="flex items-center gap-2 px-5 py-2.5 rounded-full border border-slate-300 bg-background text-foreground text-sm font-semibold hover:bg-slate-50 transition-colors cta-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (251) 765-0333
        </a>
        <a href="https://calendar.app.google/RUTjw3N7Afe95Tkk8" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-2.5 rounded-full bg-primary hover:bg-accent text-white text-sm font-bold transition-colors shadow-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
          Book a Time to Talk
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 nav-link hover:text-accent hover:opacity-80 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="menu-icon"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="close-icon hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="hidden lg:hidden bg-background text-slate-800 border-t border-border shadow-2xl absolute top-full left-0 w-full h-[calc(100vh-80px)] overflow-y-auto">
    <div class="px-4 py-6 flex flex-col gap-6">
      
      <div class="flex flex-col gap-2">
        <button id="mobile-services-btn" class="flex items-center justify-between font-bold text-xl py-2 w-full text-left">
          Services
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div id="mobile-services-panel" class="hidden flex-col bg-white/5 rounded-xl overflow-hidden mt-2">
          <a href="/get-more-leads" class="px-5 py-3.5 border-b border-slate-100 hover:bg-white/10 text-slate-700">PPC Advertising for Contractors</a>
          <a href="/track-calls-leads" class="px-5 py-3.5 border-b border-slate-100 hover:bg-white/10 text-slate-700">Lead Generation & Tracking</a>
          <a href="/answer-my-calls" class="px-5 py-3.5 border-b border-slate-100 hover:bg-white/10 text-slate-700">AI Answering Service</a>
          <a href="/ai-chatbot" class="px-5 py-3.5 border-b border-slate-100 hover:bg-white/10 text-slate-700">AI Chatbot Integration</a>
          <a href="/contractor-website" class="px-5 py-3.5 border-b border-slate-100 hover:bg-white/10 text-slate-700">Contractor Website Design</a>
          <a href="/google-maps" class="px-5 py-3.5 border-b border-slate-100 hover:bg-white/10 text-slate-700">Google Maps Optimization</a>
          <a href="/5-star-reviews" class="px-5 py-3.5 hover:bg-white/10 text-slate-700">5-Star Review Generation</a>
        </div>
      </div>
      
      <a href="/industries" class="font-bold text-xl py-2 border-t border-slate-100">Industries</a>
      <a href="/videos" class="font-bold text-xl py-2 border-t border-slate-100">Videos</a>
      <a href="/modern-web-blueprint" class="font-bold text-xl py-2 border-t border-slate-100">Blueprint</a>
      <a href="/#testimonials" class="font-bold text-xl py-2 border-t border-slate-100">Reviews</a>

      <div class="flex flex-col gap-4 mt-4 pt-6 border-t border-slate-100">
        <a href="https://calendar.app.google/RUTjw3N7Afe95Tkk8" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 px-6 py-4 rounded-xl bg-primary text-white font-bold text-lg text-center w-full">
          Book a Time to Talk
        </a>
        <a href="tel:+12517650333" class="flex items-center justify-center gap-2 px-6 py-4 rounded-xl border border-slate-300 bg-white/5 text-slate-800 font-bold text-lg text-center w-full">
          (251) 765-0333
        </a>
      </div>
      
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('site-header');
  const navLinks = document.querySelectorAll('.nav-link, .logo-text, .cta-outline');
  
  // Scroll behavior (disabled since we use solid background)
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header.classList.add('shadow-sm');
    } else {
      header.classList.remove('shadow-sm');
    }
  });

  // Mobile menu toggle
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.querySelector('.menu-icon');
  const closeIcon = document.querySelector('.close-icon');

  if (mobileBtn) {
    mobileBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
      menuIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      
      // Force solid header when menu is open
      if (!mobileMenu.classList.contains('hidden')) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
      }
    });
  }

  // Mobile services accordion
  const servicesBtn = document.getElementById('mobile-services-btn');
  const servicesPanel = document.getElementById('mobile-services-panel');
  const chevron = servicesBtn?.querySelector('svg');

  if (servicesBtn) {
    servicesBtn.addEventListener('click', () => {
      servicesPanel.classList.toggle('hidden');
      servicesPanel.classList.toggle('flex');
      chevron.classList.toggle('rotate-180');
    });
  }
</script>

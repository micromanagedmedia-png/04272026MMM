              </div>
            </div>
            
            <p class="text-slate-700 text-sm leading-relaxed mb-6 italic whitespace-pre-wrap">"{review.text}"</p>
            
            <div class="pt-4 border-t border-border flex items-center gap-3">
              <img src={review.photo} alt={review.name} class="w-10 h-10 rounded-full" loading="lazy" />
              <div>
                <p class="text-foreground font-bold text-sm leading-tight">{review.name}</p>
                <p class="text-slate-500 text-xs">{review.time}</p>
